# AVCS DNA Industrial Monitor - Example Environment Configuration
# Copy this file to .env and modify for your local setup

# Application Settings
APP_NAME="AVCS DNA Industrial Monitor"
APP_VERSION="6.0.0"
APP_ICON="🏭"

# Simulation Settings
SIMULATION_CYCLES=100
UPDATE_INTERVAL=0.5
MAX_HISTORY_POINTS=1000

# Model Settings
MODEL_PATH=models/isolation_forest.pkl

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Database Settings (optional)
DATABASE_URL=sqlite:///data/readings.db

# Alert Settings
ENABLE_EMAIL_ALERTS=false
ALERT_EMAIL=your-email@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-username
SMTP_PASSWORD=your-password

# Security (change this in production!)
SECRET_KEY=your-secret-key-here-change-this
ALLOWED_HOSTS=localhost,127.0.0.1

# Performance
CACHE_TTL=300
MAX_WORKERS=4

# Streamlit Settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_THEME=dark
